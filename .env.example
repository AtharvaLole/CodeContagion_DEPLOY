# Copy only the variables you need into each app's local env file.
# Frontend env belongs in apps/frontend/.env
# Backend env belongs in apps/backend/.env
# AI service env belongs in apps/ai-apis/.env

# Frontend
VITE_API_BASE_URL=https://cc-deploy-pzl7.onrender.com
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Backend
PORT=4000
NODE_ENV=development
CORS_ORIGIN=*
JWT_SECRET=replace-with-a-long-random-secret
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
AI_PROVIDER=groq
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_ID=meta/llama-3.1-8b-instruct
PISTON_API_URL=https://emkc.org/api/v2/piston
DEBUG_ARENA_AI_URL=http://localhost:5001/debug-arena
MISINFO_SIM_AI_URL=http://localhost:5001/misinfosim

# AI service
ENABLE_API_DOCS=true
